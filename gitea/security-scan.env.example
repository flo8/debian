# Copy to /etc/gitea-security.env and `chmod 600`. Sourced by security-scan.sh.

# Gitea API token with read access to the scanned repositories.
GITEA_TOKEN="paste-token-here"

# Org whose repositories are scanned.
# NOTE: this targets an ORG (/api/v1/orgs/<ORG>/repos). To scan a personal
# user's repos instead, change the endpoint in security-scan.sh to
# /api/v1/users/<USER>/repos.
ORG="your-org"

# Optional overrides (defaults shown).
#GITEA_URL="http://127.0.0.1:3000"
#BASE_DIR="/srv/gitea-security"
#RETENTION_DAYS="30"
