# Copy to /etc/gitea-security.env and `chmod 600`.
# Sourced by security-lib.sh (and therefore by every scan tier).
#
# Every setting has a sane default, so this file is OPTIONAL. The most likely
# thing you want to set is the Slack webhook for alerts/heartbeats.

# Slack incoming-webhook URL. Leave empty to disable Slack (scans still run and
# write reports to disk). Findings post a red alert; the daily run also posts a
# green "all clean" heartbeat so you know it ran.
SLACK_WEBHOOK_URL=""

# Send a Slack heartbeat from the FAST (hourly) tier even when it finds nothing.
# Off by default so the hourly cadence does not spam the channel.
#NOTIFY_ON_SUCCESS="0"

# ── Repo location (auto-detected; override only if your layout differs) ─────────
# The scans read Gitea's bare repos straight off disk — no API token needed.
# By default the path is resolved from the Docker named volume below.
#GITEA_VOLUME="gitea_gitea_data"
#GITEA_REPOS_DIR="/var/lib/docker/volumes/gitea_gitea_data/_data/gitea/repositories"

# ── Working area + retention ───────────────────────────────────────────────────
#BASE_DIR="/srv/gitea-security"
#RETENTION_DAYS="30"
