#!/bin/bash

# Side-by-side box rendering uses bash extglob for the ANSI-strip pattern
# in visible_len, and a UTF-8 locale so ${#var} counts characters (not bytes).
shopt -s extglob

# colors ÔÇö use $'...' so these are real ESC bytes, not literal "\033" text.
# That way every string we build (including command-substitution output from
# disk_bar) has the same form, and visible_len only needs to strip one shape.
PUR=$'\033[0;35m'
GRN=$'\033[0;32m'
YLW=$'\033[0;33m'
CYN=$'\033[0;36m'
BLU=$'\033[0;34m'
RED=$'\033[0;31m'
DIM=$'\033[2;37m'
RST=$'\033[0m'

# VARIABLES
HOST="$(hostname)"
UPTIME="$(uptime -p | sed 's/up //')"
LOAD="$(awk '{print $1, $2, $3}' /proc/loadavg)"
MEM="$(free -h | awk '/Mem:/ {print $3 "/" $2}')"
MEM_PCT="$(free | awk '/Mem:/ {printf "%.0f", $3/$2 * 100}')"
DISK="$(df -h / | awk 'NR==2 {print $3 "/" $2}')"
DISK_PCT="$(df / | awk 'NR==2 {print $5}' | tr -d '%')"
IP="$(hostname -I 2>/dev/null | awk '{print $1}')"
KERNEL="$(uname -r)"

# Distro name/version ÔÇö sourced from /etc/os-release (the standard on Debian).
# We use $ID ("debian") rather than $NAME ("Debian GNU/Linux") so the label
# stays compact (e.g. "debian 13"). Falls back to "debian" if the file is missing.
OS_ID="debian"
OS_VERSION=""
if [ -r /etc/os-release ]; then
  . /etc/os-release
  OS_ID="${ID:-debian}"
  OS_VERSION="${VERSION_ID:-}"
fi
OS_LABEL="${OS_ID} ${OS_VERSION}"

# Last apt update ÔÇö derived from the pkgcache.bin mtime, refreshed by `apt update`.
# Stat is instant; we render as "Nd ago" so the line stays short.
APT_TS="$(stat -c %Y /var/cache/apt/pkgcache.bin 2>/dev/null || echo 0)"
if (( APT_TS > 0 )); then
  APT_AGE_DAYS=$(( ($(date +%s) - APT_TS) / 86400 ))
  APT_LAST="${APT_AGE_DAYS}d ago"
else
  APT_LAST="unknown"
fi

# Reboot required marker ÔÇö populated by unattended-upgrades / needrestart when
# a kernel or libc update lands. Absent file = no reboot needed, so silent.
REBOOT_REQUIRED=""
[ -f /var/run/reboot-required ] && REBOOT_REQUIRED="yes"

# USAGE BAR ÔÇö generic % bar reused by disk and RAM rows.
# Second arg is the "empty" shade char: pass ÔľĹ (light, CP437 176) or
# Ôľĺ (medium, CP437 177) so two adjacent bars are easy to tell apart.
usage_bar() {
  local pct=$1
  local empty_char=${2:-ÔľĹ}
  local width=12
  local filled=$(( pct * width / 100 ))
  local empty=$(( width - filled ))
  # MSDOS-style bar: Ôľł (full block, CP437 219) for used.
  # Evokes SCANDISK/DEFRAG.
  local bar=""
  for ((i=0; i<filled; i++)); do bar+="Ôľł"; done
  for ((i=0; i<empty; i++)); do bar+="$empty_char"; done

  # Stay dim by default ÔÇö only colorize when usage gets close to full,
  # so the bar doesn't shout for attention when nothing's wrong.
  local color=$DIM
  (( pct >= 70 )) && color=$YLW
  (( pct >= 85 )) && color=$RED

  # printf (not echo -e) so the output keeps the same form as the rest of
  # the strings we build ÔÇö $color/$RST already hold real ESC bytes.
  printf '%s%s %s%%%s' "$color" "$bar" "$pct" "$RST"
}

# One-line header in place of the old multi-row ASCII banner.
printf '%sÔĽÉÔĽÉÔĽÉ Welcome to %s | Kernel %s ÔĽÉÔĽÉÔĽÉ%s\n' "$PUR" "$OS_LABEL" "$KERNEL" "$RST"

# Left column: host + system stats. No separator lines now ÔÇö the box draws them.
LEFT=(
  "${PUR}machine${RST} : ${BLU}$HOST${RST}"
  "${PUR}uptime${RST}  : ${DIM}$UPTIME${RST}"
  "${PUR}load${RST}    : ${DIM}$LOAD${RST}"
  "${PUR}ram${RST}     : $(usage_bar $MEM_PCT ÔľĹ) ${DIM}($MEM)${RST}"
  "${PUR}disk${RST}    : $(usage_bar $DISK_PCT Ôľĺ) ${DIM}($DISK)${RST}"
  "${PUR}ip${RST}      : ${DIM}$IP${RST}"
  "${PUR}apt${RST}     : ${DIM}$APT_LAST${RST}"
)

# Conditionally append a loud reboot-required row so it stands out.
if [ -n "$REBOOT_REQUIRED" ]; then
  LEFT+=("${RED}* reboot required${RST}")
fi

# Right column: tips / shortcut cheatsheet.
RIGHT=(
  "${DIM}tips${RST}"
  "${PUR}ctrl+r${RST}  ${DIM}history search${RST}"
  "${PUR}ctrl+t${RST}  ${DIM}find file (fzf)${RST}"
  "${PUR}ctrl+x > ctrl+e${RST}  ${DIM}edit current command${RST}"
  "${PUR}editors${RST} ${DIM}vim | hx | micro${RST}"
  "${PUR}admin${RST}   ${DIM}tmux | tree | mc | fzf | bat${RST}"
  "${PUR}network${RST} ${DIM}ufw | myip | iftop | s3cmd${RST}"
  "${PUR}system${RST}  ${DIM}htop | strace | ncdu | duf | perf | dstat${RST}"
)

# Strip ANSI escape sequences and return the visible character count.
# Pattern uses extglob *([0-9;]) to match any "[0;35m"-style payload.
visible_len() {
  local stripped="${1//$'\033'\[*([0-9;])m/}"
  echo "${#stripped}"
}

# Compute column widths from the widest visible line in each side.
left_max=0
right_max=0
for line in "${LEFT[@]}"; do
  w=$(visible_len "$line")
  (( w > left_max )) && left_max=$w
done
for line in "${RIGHT[@]}"; do
  w=$(visible_len "$line")
  (( w > right_max )) && right_max=$w
done

# Repeat a single character N times ÔÇö used to build horizontal borders.
repeat() {
  local char=$1
  local count=$2
  local i out=""
  for ((i=0; i<count; i++)); do out+="$char"; done
  printf '%s' "$out"
}

# Build a horizontal border: <left><ÔĽÉ...ÔĽÉ><mid><ÔĽÉ...ÔĽÉ><right>.
# The +2 on each side accounts for the single-space padding inside each cell.
build_border() {
  local lc=$1 mc=$2 rc=$3
  printf '%s%s%s%s%s\n' "$lc" "$(repeat 'ÔĽÉ' $((left_max+2)))" "$mc" "$(repeat 'ÔĽÉ' $((right_max+2)))" "$rc"
}

top_border=$(build_border 'ÔĽö' 'ÔĽĄ' 'ÔĽŚ')
bot_border=$(build_border 'ÔĽÜ' 'ÔĽž' 'ÔĽŁ')

# Top border (purple to match the theme).
printf '%s%s%s\n' "$PUR" "$top_border" "$RST"

# Print each row inside the box: ÔĽĹ <left, padded> Ôöé <right, padded> ÔĽĹ.
n_left=${#LEFT[@]}
n_right=${#RIGHT[@]}
n_max=$(( n_left > n_right ? n_left : n_right ))

for (( i = 0; i < n_max; i++ )); do

  # Missing rows on either side just become empty strings.
  lpart="${LEFT[i]:-}"
  rpart="${RIGHT[i]:-}"

  # Pad each cell out to its column width so the right border lines up.
  lw=$(visible_len "$lpart")
  rw=$(visible_len "$rpart")

  lpad=""
  rpad=""
  (( left_max  - lw > 0 )) && lpad=$(printf '%*s' "$((left_max  - lw))" '')
  (( right_max - rw > 0 )) && rpad=$(printf '%*s' "$((right_max - rw))" '')

  printf '%sÔĽĹ%s %s%s %sÔöé%s %s%s %sÔĽĹ%s\n' \
    "$PUR" "$RST" "$lpart" "$lpad" \
    "$PUR" "$RST" "$rpart" "$rpad" \
    "$PUR" "$RST"
done

# Bottom border.
printf '%s%s%s\n' "$PUR" "$bot_border" "$RST"

echo ""
