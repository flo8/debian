#!/bin/bash

# Side-by-side box rendering uses bash extglob for the ANSI-strip pattern
# in visible_len, and a UTF-8 locale so ${#var} counts characters (not bytes).
shopt -s extglob

# colors Рђћ use $'...' so these are real ESC bytes, not literal "\033" text.
# That way every string we build (including command-substitution output from
# disk_bar) has the same form, and visible_len only needs to strip one shape.
PUR=$'\033[0;35m'
GRN=$'\033[0;32m'
YLW=$'\033[0;33m'
CYN=$'\033[0;36m'
BLU=$'\033[0;34m'
RED=$'\033[0;31m'
DIM=$'\033[2;37m'
RST=$'\033[0m'

# VARIABLES
HOST="$(hostname)"
UPTIME="$(uptime -p | sed 's/up //')"
LOAD="$(awk '{print $1, $2, $3}' /proc/loadavg)"
MEM="$(free -h | awk '/Mem:/ {print $3 "/" $2}')"
DISK="$(df -h / | awk 'NR==2 {print $3 "/" $2}')"
DISK_PCT="$(df / | awk 'NR==2 {print $5}' | tr -d '%')"
IP="$(hostname -I 2>/dev/null | awk '{print $1}')"
KERNEL="$(uname -r)"

# Last apt update Рђћ derived from the pkgcache.bin mtime, refreshed by `apt update`.
# Stat is instant; we render as "Nd ago" so the line stays short.
APT_TS="$(stat -c %Y /var/cache/apt/pkgcache.bin 2>/dev/null || echo 0)"
if (( APT_TS > 0 )); then
  APT_AGE_DAYS=$(( ($(date +%s) - APT_TS) / 86400 ))
  APT_LAST="${APT_AGE_DAYS}d ago"
else
  APT_LAST="unknown"
fi

# Reboot required marker Рђћ populated by unattended-upgrades / needrestart when
# a kernel or libc update lands. Absent file = no reboot needed, so silent.
REBOOT_REQUIRED=""
[ -f /var/run/reboot-required ] && REBOOT_REQUIRED="yes"

# DISK BAR
disk_bar() {
  local pct=$1
  local width=12
  local filled=$(( pct * width / 100 ))
  local empty=$(( width - filled ))
  local bar="["
  for ((i=0; i<filled; i++)); do bar+="Рќа"; done
  for ((i=0; i<empty; i++)); do bar+="РќА"; done
  bar+="]"

  local color=$GRN
  (( pct >= 80 )) && color=$YLW
  (( pct >= 90 )) && color=$RED

  # printf (not echo -e) so the output keeps the same form as the rest of
  # the strings we build Рђћ $color/$RST already hold real ESC bytes.
  printf '%s%s %s%%%s' "$color" "$bar" "$pct" "$RST"
}

# One-line header in place of the old multi-row ASCII banner.
printf '%sРЋљРЋљРЋљ Welcome to Debian13 | Kernel %s РЋљРЋљРЋљ%s\n' "$PUR" "$KERNEL" "$RST"

# Left column: host + system stats. No separator lines now Рђћ the box draws them.
LEFT=(
  "${BLU}РќБ $HOST${RST}"
  "${PUR}uptime${RST} : ${DIM}$UPTIME${RST}"
  "${PUR}load${RST}   : ${DIM}$LOAD${RST}"
  "${PUR}ram${RST}    : ${DIM}$MEM${RST}"
  "${PUR}disk${RST}   : ${DIM}$DISK${RST} $(disk_bar $DISK_PCT)"
  "${PUR}ip${RST}     : ${DIM}$IP${RST}"
  "${PUR}apt${RST}    : ${DIM}$APT_LAST${RST}"
)

# Conditionally append a loud reboot-required row so it stands out.
if [ -n "$REBOOT_REQUIRED" ]; then
  LEFT+=("${RED}РЌЈ reboot required${RST}")
fi

# Right column: tips / shortcut cheatsheet.
RIGHT=(
  "${DIM}tips${RST}"
  "${PUR}ctrl+r${RST}  ${DIM}history search${RST}"
  "${PUR}ctrl+t${RST}  ${DIM}find file (fzf)${RST}"
  "${PUR}ctrl+x Ръю ctrl+e${RST}  ${DIM}edit current command${RST}"
  "${PUR}editors${RST} ${DIM}vim ┬и hx ┬и micro${RST}"
  "${PUR}admin${RST} ${DIM}ufw, tmux, tree, mc, s3cmd, fzf, bat${RST}"
  "${PUR}debug${RST} ${DIM}htop strace ncdu duf myip iftop perf dstat${RST}"
)

# Strip ANSI escape sequences and return the visible character count.
# Pattern uses extglob *([0-9;]) to match any "[0;35m"-style payload.
visible_len() {
  local stripped="${1//$'\033'\[*([0-9;])m/}"
  echo "${#stripped}"
}

# Compute column widths from the widest visible line in each side.
left_max=0
right_max=0
for line in "${LEFT[@]}"; do
  w=$(visible_len "$line")
  (( w > left_max )) && left_max=$w
done
for line in "${RIGHT[@]}"; do
  w=$(visible_len "$line")
  (( w > right_max )) && right_max=$w
done

# Repeat a single character N times Рђћ used to build horizontal borders.
repeat() {
  local char=$1
  local count=$2
  local i out=""
  for ((i=0; i<count; i++)); do out+="$char"; done
  printf '%s' "$out"
}

# Build a horizontal border: <left><РЋљ...РЋљ><mid><РЋљ...РЋљ><right>.
# The +2 on each side accounts for the single-space padding inside each cell.
build_border() {
  local lc=$1 mc=$2 rc=$3
  printf '%s%s%s%s%s\n' "$lc" "$(repeat 'РЋљ' $((left_max+2)))" "$mc" "$(repeat 'РЋљ' $((right_max+2)))" "$rc"
}

top_border=$(build_border 'РЋћ' 'РЋц' 'РЋЌ')
bot_border=$(build_border 'РЋџ' 'РЋД' 'РЋЮ')

# Top border (purple to match the theme).
printf '%s%s%s\n' "$PUR" "$top_border" "$RST"

# Print each row inside the box: РЋЉ <left, padded> Рћѓ <right, padded> РЋЉ.
n_left=${#LEFT[@]}
n_right=${#RIGHT[@]}
n_max=$(( n_left > n_right ? n_left : n_right ))

for (( i = 0; i < n_max; i++ )); do

  # Missing rows on either side just become empty strings.
  lpart="${LEFT[i]:-}"
  rpart="${RIGHT[i]:-}"

  # Pad each cell out to its column width so the right border lines up.
  lw=$(visible_len "$lpart")
  rw=$(visible_len "$rpart")

  lpad=""
  rpad=""
  (( left_max  - lw > 0 )) && lpad=$(printf '%*s' "$((left_max  - lw))" '')
  (( right_max - rw > 0 )) && rpad=$(printf '%*s' "$((right_max - rw))" '')

  printf '%sРЋЉ%s %s%s %sРћѓ%s %s%s %sРЋЉ%s\n' \
    "$PUR" "$RST" "$lpart" "$lpad" \
    "$PUR" "$RST" "$rpart" "$rpad" \
    "$PUR" "$RST"
done

# Bottom border.
printf '%s%s%s\n' "$PUR" "$bot_border" "$RST"

echo ""
