#!/bin/bash
# colors
PUR='\033[0;35m'
GRN='\033[0;32m'
YLW='\033[0;33m'
CYN='\033[0;36m'
RED='\033[0;31m'
RST='\033[0m'
# VARIABLES
HOST="$(hostname)"
UPTIME="$(uptime -p | sed 's/up //')"
LOAD="$(awk '{print $1, $2, $3}' /proc/loadavg)"
MEM="$(free -h | awk '/Mem:/ {print $3 "/" $2}')"
DISK="$(df -h / | awk 'NR==2 {print $3 "/" $2}')"
DISK_PCT="$(df / | awk 'NR==2 {print $5}' | tr -d '%')"
IP="$(hostname -I 2>/dev/null | awk '{print $1}')"

# DISK BAR
disk_bar() {
  local pct=$1
  local width=12
  local filled=$(( pct * width / 100 ))
  local empty=$(( width - filled ))
  local bar="["
  for ((i=0; i<filled; i++)); do bar+="в– "; done
  for ((i=0; i<empty; i++)); do bar+="в–Ў"; done
  bar+="]"

  local color=$GRN
  (( pct >= 80 )) && color=$YLW
  (( pct >= 90 )) && color=$RED

  echo -e "${color}${bar} ${pct}%${RST}"
}

# 3D-ASCII font on https://patorjk.com/software/taag/#p=testall&f=Bulbhead&t=air360&x=none&v=4&h=4&w=80&we=false
echo -e "${PUR}"
cat << "EOF"
 ________  ___  ________  ________  ________  ________
|\   __  \|\  \|\   __  \|\_____  \|\   ____\|\   __  \
\ \  \|\  \ \  \ \  \|\  \|____|\ /\ \  \___|\ \  \|\  \
 \ \   __  \ \  \ \   _  _\    \|\  \ \  \____\ \  \\\  \
  \ \  \ \  \ \  \ \  \\  \|  __\_\  \ \  ___  \ \  \\\  \
   \ \__\ \__\ \__\ \__\\ _\ |\_______\ \_______\ \_______\
    \|__|\|__|\|__|\|__|\|__|\|_______|\|_______|\|_______|
EOF
echo -e "${RST}"

# PRINT
echo -e "${PUR}в–Ј $HOST${RST}"
echo -e "${PUR}в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ${RST}"
echo -e "${YLW}uptime${RST} : $UPTIME"
echo -e "${YLW}load${RST}   : $LOAD"
echo -e "${YLW}ram${RST}    : ${GRN}$MEM${RST}"
echo -e "${YLW}disk${RST}   : ${GRN}$DISK${RST} $(disk_bar $DISK_PCT)"
echo -e "${YLW}ip${RST}     : ${GRN}$IP${RST}"
echo -e "${PUR}в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ${RST}"
echo -e "${YLW}tips${RST}"
echo -e "  ${CYN}ctrl+r${RST}  history search"
echo -e "  ${CYN}ctrl+x вћњ ctrl+e${RST}  edit current command"
echo -e "  ${CYN}editors${RST} vim В· hx В· micro"
echo -e "  ${CYN}shell${RST}   bash"
echo -e "  ${CYN}admin${RST} ufw, tmux, tree, mc, s3cmd, fzf, bat"
echo -e "  ${CYN}debug${RST} htop strace ncdu duf myip iftop perf dstat"
echo -e "${PUR}в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ${RST}"
echo ""
